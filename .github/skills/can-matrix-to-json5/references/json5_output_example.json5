// ============================================================
// CAN Matrix JSON5 输出示例
// 节点对：VDCU（NODE1）<-> HVASAirPump（NODE2）
// 来源：DeepWay E2505 CAN FD HVAS AirPump Matrix V2.4
// ============================================================
//
// 格式说明：
//   NODE1 / NODE2    : 两个通信节点的名称
//   MSGS             : 报文数组
//   ID               : 报文帧 ID，0x开头8位大写十六进制
//   MSGNAME          : Rx{N}_0x{ID} 表示 NODE2 接收，Tx{N}_0x{ID} 表示 NODE2 发送
//   DLC              : 帧长度（字节）
//   TXNODE / RXNODE  : 发送节点 / 接收节点
//   SIGS             : 信号数组
//   SIG              : 信号名称（补空格对齐到22字符）
//   SBIT             : 信号起始位（Intel字节序从 LSB 位置开始）
//   LEN              : 信号长度（bit）
//   FACTOR           : 精度（物理值 = 总线值 × FACTOR + OFFSET）
//   OFFSET           : 偏移量
//   MIN / MAX        : 总线层原始值范围（十六进制列转换后的整数）
//   UINT             : 单位（空字符串表示无单位）
//   COMMENT          : 信号描述（中英文合并，\n替换为空格）
//
{
    NODE1: "VDCU",
    NODE2: "HVASAirPump",
    MSGS: [
// +----------------------------------------------------------------------------------------------------------------------+
// | ID    MSGNAME   DLC  TXNODE   RXNODE   SIGS    SIG      SBIT   LEN      FACTOR  OFFSET  MIN   MAX    UINT  COMMENT  |
// +----------------------------------------------------------------------------------------------------------------------+

    // ── VDCU 发送 → HVASAirPump 接收（Rx 类） ──────────────────────────────────

    {ID: 0x0CFE6CEE, MSGNAME: "Rx0_0x0CFE6CEE", DLC: 8, TXNODE:"VDCU", RXNODE:"HVASAirPump", SIGS:[
        // 整车实际车速。FACTOR=0.00390625 对应 Resolution=1/256
        {SIG: "VDCU_VehActSpd        ",	SBIT: 48,	LEN: 16,	FACTOR: 0.00390625,  	OFFSET: 0,  	MIN: 0,  	MAX: 65535,   	UINT:"km/h",  	COMMENT: "Vehicle actual speed 整车实际车速"},
    ]},
// +----------------------------------------------------------------------------------------------------------------------+

    {ID: 0x18FEC117, MSGNAME: "Rx1_0x18FEC117", DLC: 8, TXNODE:"VDCU", RXNODE:"HVASAirPump", SIGS:[
        // 32位信号跨4字节，物理最大值 10,000,000 km
        {SIG: "VDCU_VehTotDst        ",	SBIT: 0,	LEN: 32,	FACTOR: 1,  	OFFSET: 0,  	MIN: 0,  	MAX: 4294967295,   	UINT:"kM",  	COMMENT: "Vehicle total distance 整车总里程"},
    ]},
// +----------------------------------------------------------------------------------------------------------------------+

    {ID: 0x18FF5227, MSGNAME: "Rx2_0x18FF5227", DLC: 8, TXNODE:"VDCU", RXNODE:"HVASAirPump", SIGS:[
        // Byte 0：CRC 校验字节
        {SIG: "VDCU_HVASCmd_CRC      ",	SBIT: 0,	LEN: 8,	FACTOR: 1,  	OFFSET: 0,  	MIN: 0,  	MAX: 255,   	UINT:"",  	COMMENT: "CRC8"},
        // Byte 1 低4位：滚动计数器 0~14，0xF 保留
        {SIG: "VDCU_HVASCmd_AC       ",	SBIT: 8,	LEN: 4,	FACTOR: 1,  	OFFSET: 0,  	MIN: 0,  	MAX: 15,   	UINT:"",  	COMMENT: "Alive Counter"},
        // Byte 2 bit[1:0]（从 sbit=18）：0=停机 1=运行 2~3=保留
        {SIG: "VDCU_AirPmpWrkModReq  ",	SBIT: 18,	LEN: 2,	FACTOR: 1,  	OFFSET: 0,  	MIN: 0,  	MAX: 3,   	UINT:"",  	COMMENT: "Air pump working mode request 空压机DCAC工作模式请求"},
    ]},
// +----------------------------------------------------------------------------------------------------------------------+

    // ── 第三方节点广播（MCUF 发送，VDCU 和 HVASAirPump 均接收）──────────────────

    {ID: 0x0CFF1108, MSGNAME: "Tx3_0x0CFF1108", DLC: 8, TXNODE:"MCUF", RXNODE:"HVASAirPump", SIGS:[
        // 前电机实际转速，OFFSET=-20000 表示总线值0对应 -20000 rpm
        {SIG: "MCUF_FrMotActSpd      ",	SBIT: 32,	LEN: 16,	FACTOR: 1,  	OFFSET: -20000,  	MIN: 0,  	MAX: 65535,   	UINT:"rpm",  	COMMENT: "Actual speed of front motor 前电机实际转速"},
    ]},
// +----------------------------------------------------------------------------------------------------------------------+

    // ── HVASAirPump 发送 → VDCU 接收（Tx 类） ──────────────────────────────────

    {ID: 0x18FF9DE5, MSGNAME: "Tx4_0x18FF9DE5", DLC: 8, TXNODE:"HVASAirPump", RXNODE:"VDCU", SIGS:[
        {SIG: "HVAS_AirPmpSt1_CRC    ",	SBIT: 0,	LEN: 8,	FACTOR: 1,  	OFFSET: 0,  	MIN: 0,  	MAX: 255,   	UINT:"",  	COMMENT: "CRC8"},
        {SIG: "HVAS_AirPmpSt1_AC     ",	SBIT: 8,	LEN: 4,	FACTOR: 1,  	OFFSET: 0,  	MIN: 0,  	MAX: 15,   	UINT:"",  	COMMENT: "Alive Counter"},
        {SIG: "HVAS_AirPmpFltLvl     ",	SBIT: 12,	LEN: 4,	FACTOR: 1,  	OFFSET: 0,  	MIN: 0,  	MAX: 15,   	UINT:"",  	COMMENT: "Air pump fault level 气泵故障等级"},
        {SIG: "HVAS_AirPmpRadrT      ",	SBIT: 16,	LEN: 8,	FACTOR: 1,  	OFFSET: -40,  	MIN: 0,  	MAX: 255,   	UINT:"℃",  	COMMENT: "Air pump radiator temperature 气泵散热温度"},
        {SIG: "HVAS_AirPmpInpVolt    ",	SBIT: 24,	LEN: 16,	FACTOR: 0.1,  	OFFSET: -1000,  	MIN: 0,  	MAX: 65535,   	UINT:"V",  	COMMENT: "Air pump input voltage 气泵输入电压"},
        // Byte 5~7: 故障位（每位1bit，0=正常 1=故障）
        {SIG: "HVAS_AirPmpPwrFlt     ",	SBIT: 46,	LEN: 1,	FACTOR: 1,  	OFFSET: 0,  	MIN: 0,  	MAX: 1,   	UINT:"",  	COMMENT: "Power fault 电源故障"},
        {SIG: "HVAS_AirPmpHardFlt    ",	SBIT: 47,	LEN: 1,	FACTOR: 1,  	OFFSET: 0,  	MIN: 0,  	MAX: 1,   	UINT:"",  	COMMENT: "Hardware fault 硬件故障"},
        {SIG: "HVAS_AirPmpOverHeatFlt",	SBIT: 48,	LEN: 1,	FACTOR: 1,  	OFFSET: 0,  	MIN: 0,  	MAX: 1,   	UINT:"",  	COMMENT: "Air Pump IGBT overheating Fault 气泵IGBT过热故障"},
        {SIG: "HVAS_AirPmpInpUnderVoltFlt",	SBIT: 49,	LEN: 1,	FACTOR: 1,  	OFFSET: 0,  	MIN: 0,  	MAX: 1,   	UINT:"",  	COMMENT: "Air Pump input undervoltage Fault 气泵输入欠压故障"},
        {SIG: "HVAS_AirPmpInpOverVoltFlt",	SBIT: 50,	LEN: 1,	FACTOR: 1,  	OFFSET: 0,  	MIN: 0,  	MAX: 1,   	UINT:"",  	COMMENT: "Air Pump input overvoltage Fault 气泵输入过压故障"},
        {SIG: "HVAS_AirPmpOutpOverCurrFlt",	SBIT: 51,	LEN: 1,	FACTOR: 1,  	OFFSET: 0,  	MIN: 0,  	MAX: 1,   	UINT:"",  	COMMENT: "Air Pump Output overcurrent Fault 气泵输出过流故障"},
        {SIG: "HVAS_AirPmpOutpPhaLossFlt",	SBIT: 52,	LEN: 1,	FACTOR: 1,  	OFFSET: 0,  	MIN: 0,  	MAX: 1,   	UINT:"",  	COMMENT: "Air Pump Output phase loss Fault 气泵输出缺相故障"},
        {SIG: "HVAS_AirPmpComFlt     ",	SBIT: 53,	LEN: 1,	FACTOR: 1,  	OFFSET: 0,  	MIN: 0,  	MAX: 1,   	UINT:"",  	COMMENT: "Air Pump Communication fault 气泵通信故障"},
        {SIG: "HVAS_AirPmpIGBTFlt    ",	SBIT: 54,	LEN: 1,	FACTOR: 1,  	OFFSET: 0,  	MIN: 0,  	MAX: 1,   	UINT:"",  	COMMENT: "Air Pump IGBT module fault (protection triggered) 气泵IGBT模块故障（触发保护）"},
        {SIG: "HVAS_AirPmpMotOverloadFlt",	SBIT: 55,	LEN: 1,	FACTOR: 1,  	OFFSET: 0,  	MIN: 0,  	MAX: 1,   	UINT:"",  	COMMENT: "Air Pump Motor overload (output current) 气泵电机过载(根据输出电流)"},
        {SIG: "HVAS_AirPmpTMdulDcnctnFlt",	SBIT: 56,	LEN: 1,	FACTOR: 1,  	OFFSET: 0,  	MIN: 0,  	MAX: 1,   	UINT:"",  	COMMENT: "Air Pump module temperature is disconnected 气泵模块温度断开"},
        {SIG: "HVAS_AirPmpOutpShrt2Gnd",	SBIT: 57,	LEN: 1,	FACTOR: 1,  	OFFSET: 0,  	MIN: 0,  	MAX: 1,   	UINT:"",  	COMMENT: "Air Pump Output short circuit to ground 气泵输出对地短路"},
        {SIG: "HVAS_AirPmpExtFlt     ",	SBIT: 58,	LEN: 1,	FACTOR: 1,  	OFFSET: 0,  	MIN: 0,  	MAX: 1,   	UINT:"",  	COMMENT: "HVAS Air Pump Ext Fault 气泵失步故障"},
        {SIG: "HVAS_AirPmpSWOverCurr ",	SBIT: 59,	LEN: 1,	FACTOR: 1,  	OFFSET: 0,  	MIN: 0,  	MAX: 1,   	UINT:"",  	COMMENT: "Software overcurrent 软件过流"},
        {SIG: "HVAS_AirPmpSWOverVolt ",	SBIT: 60,	LEN: 1,	FACTOR: 1,  	OFFSET: 0,  	MIN: 0,  	MAX: 1,   	UINT:"",  	COMMENT: "Software overvoltage 软件过压"},
        {SIG: "HVAS_AirPmpLowVoltOverVolt",	SBIT: 61,	LEN: 1,	FACTOR: 1,  	OFFSET: 0,  	MIN: 0,  	MAX: 1,   	UINT:"",  	COMMENT: "Low voltage overvoltage 低压过压"},
        {SIG: "HVAS_AirPmpWrkSt      ",	SBIT: 63,	LEN: 1,	FACTOR: 1,  	OFFSET: 0,  	MIN: 0,  	MAX: 1,   	UINT:"",  	COMMENT: "Air Pump work state 气泵运行状态"},
    ]},
// +----------------------------------------------------------------------------------------------------------------------+

    {ID: 0x18FF9EE5, MSGNAME: "Tx5_0x18FF9EE5", DLC: 8, TXNODE:"HVASAirPump", RXNODE:"VDCU", SIGS:[
        {SIG: "HVAS_AirPmpSt2_CRC    ",	SBIT: 0,	LEN: 8,	FACTOR: 1,  	OFFSET: 0,  	MIN: 0,  	MAX: 255,   	UINT:"",  	COMMENT: "CRC8"},
        {SIG: "HVAS_AirPmpSt2_AC     ",	SBIT: 8,	LEN: 4,	FACTOR: 1,  	OFFSET: 0,  	MIN: 0,  	MAX: 15,   	UINT:"",  	COMMENT: "Alive Counter"},
        // 输出相电流，精度0.1A，OFFSET=-1000 → 物理值范围 -100A ~ 5553.5A
        {SIG: "HVAS_AirPmpOutpCurr   ",	SBIT: 16,	LEN: 16,	FACTOR: 0.1,  	OFFSET: -1000,  	MIN: 0,  	MAX: 65535,   	UINT:"A",  	COMMENT: "Air pump DC/AC output phase current 气泵输出相电流"},
        {SIG: "HVAS_AirPmpInpCurr    ",	SBIT: 32,	LEN: 16,	FACTOR: 0.1,  	OFFSET: -1000,  	MIN: 0,  	MAX: 65535,   	UINT:"A",  	COMMENT: "Air pump input current 气泵输入电流"},
        {SIG: "HVAS_AirPmpMotSpd     ",	SBIT: 48,	LEN: 16,	FACTOR: 1,  	OFFSET: 0,  	MIN: 0,  	MAX: 65535,   	UINT:"rpm",  	COMMENT: "Air pump motor speed (according to current) 气泵电机转速(根据电流计算)"},
    ]},
// +----------------------------------------------------------------------------------------------------------------------+
    ]
}
